# Anthropic API Key (Required for Claude model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API Key (Optional, for Gemini model)
GOOGLE_API_KEY=your_google_api_key_here

# Tavily API Key (Required for web search)
# Get one at https://app.tavily.com - has a generous free tier
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith API Key (Optional, for tracing and evaluation)
# Get one at https://smith.langchain.com/settings
LANGSMITH_API_KEY=your_langsmith_api_key_here
